{
  "name": "wire",
  "version": "0.1.0",
  "description": "Universal API Diff Engine — catch breaking API changes before they hit prod",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "wire": "dist/cli/wire.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --experimental-vm-modules --test tests/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "keywords": ["api", "diff", "schema", "testing", "ci", "breaking-changes"],
  "author": "effestier",
  "license": "MIT",
  "repository": {
    "type": "github",
    "url": "https://github.com/effestier/wire"
  },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "chalk": "^5",
    "cli-table3": "^0.6",
    "commander": "^12",
    "sql.js": "^1.10"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/sql.js": "^1",
    "typescript": "^5.9.3"
  }
}
